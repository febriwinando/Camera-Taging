<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <ImageView
        android:id="@+id/imgPreview"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:scaleType="fitCenter"/>

    <Button android:id="@+id/btnSave" android:text="Simpan" android:layout_height="wrap_content" android:layout_width="match_parent"/>
    <Button android:id="@+id/btnShare" android:text="Share" android:layout_height="wrap_content" android:layout_width="match_parent"/>
    <Button android:id="@+id/btnList" android:text="Daftar Foto" android:layout_height="wrap_content" android:layout_width="match_parent"/>

</LinearLayout>